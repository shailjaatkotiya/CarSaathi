APP_NAME=Carthi API
ENVIRONMENT=local
# PostgreSQL (default). Create the database first:
#   python scripts/create_postgres_db.py
# One-time data migration from a legacy SQLite file:
#   python scripts/migrate_sqlite_to_postgres.py --sqlite ./ridesaathi.db --postgres postgresql+psycopg2://postgres:postgres@localhost:5432/carthi
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/carthi
# Legacy SQLite fallback:
# DATABASE_URL=sqlite:///./carthi.db
# Empty disables caching. Docker compose injects redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
RIDE_SEARCH_CACHE_TTL=30
# Production: generate with `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
AADHAAR_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5176,http://127.0.0.1:5176
WHATSAPP_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_CONTENT_SID_PASSENGER_BOOKING_CONFIRMATION=
# Use an approved Twilio WhatsApp template with two quick reply buttons:
# Accept and Reject. The app does not process those button replies yet.
TWILIO_CONTENT_SID_DRIVER_BOOKING_REQUEST=
TWILIO_CONTENT_SID_PASSENGER_BOOKING_CANCELLED=
TWILIO_CONTENT_SID_DRIVER_BOOKING_CANCELLED=
