{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173
    },
    {
      "name": "backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "backend",
      "port": 8000
    },
    {
      "name": "celery-worker",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "celery", "-A", "app.worker.celery_app", "worker", "--loglevel=info", "--pool=solo"],
      "cwd": "backend",
      "port": 0
    }
  ]
}
